{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "[Run without debugger]",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["main.py"],
            // working directory
            "options": {
                "cwd": "${workspaceFolder}/src"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "[Run Tests]",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["-m", "pytest", "tests/"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "[Run CLI Tests]",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["-m", "pytest", "tests/test_cli.py"],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "[Run Lint]",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["-m", "flake8", "./src"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "[Build Windows EXE]",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["setup.py", "build_exe"],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "[Build macOS app+dmg]",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/build_mac.sh",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "[Build+Run macOS app]",
            "type": "shell",
            "dependsOn": "[Build macOS app+dmg]",
            "command": "bash",
            "args": [
                "-lc",
                "APP_PATH=\"\"; if [ -d \"${workspaceFolder}/build/dist/Drill.app\" ]; then APP_PATH=\"${workspaceFolder}/build/dist/Drill.app\"; elif [ -d \"${workspaceFolder}/build/Drill.app\" ]; then APP_PATH=\"${workspaceFolder}/build/Drill.app\"; else echo \"No Drill.app found after build\"; exit 1; fi; open \"$APP_PATH\""
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        }
    ]
}
